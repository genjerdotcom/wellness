generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "sqlite"
 url = env("DATABASE_URL")
}

model WellnessPackage {
 id String @id @default(uuid())
 name String
 description String
 price Float
 duration_minutes Int
 status String @default("active")
 created_at DateTime @default(now())
 updated_at DateTime @updatedAt
}